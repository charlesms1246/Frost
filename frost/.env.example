# Frost desktop app — public (client-exposed) build flags. Copy to `.env`.
# Only PUBLIC_-prefixed vars are exposed to the SvelteKit/Tauri frontend.

# Cost control: when "true", the app makes NO Venice calls anywhere —
# inference falls back to OpenRouter/Groq, RPC reads/quotes use the public Base RPC
# below, and the Venice-only web_search/fetch_url tools are disabled.
# Set to "false" (or remove) to re-enable Venice for the demo.
PUBLIC_DISABLE_VENICE=true

# Public Base mainnet RPC used as the read fallback when Venice is disabled.
PUBLIC_FALLBACK_BASE_RPC_URL=https://mainnet.base.org

# Base URL of the self-hosted x402 inference gateway (the `x402-inference` package).
# This is a STATEFUL long-running Express server (it fetches the facilitator's supported
# kinds once at boot via X402_SYNC_ON_START=true), so it is NOT a fit for Vercel serverless
# (xfrost.vercel.app). Options:
#   - DEMO (recommended): run it locally → PUBLIC_X402_INFERENCE_URL=http://localhost:4021
#     (`cd x402-inference && X402_ASSET_TRANSFER_METHOD=erc7710 X402_SYNC_ON_START=true \
#       EVM_ADDRESS=<sellerWallet> OPENROUTER_API_KEY=<key> node dist/server.js`)
#   - PUBLIC: deploy to a long-running host (Render/Railway/Fly/VPS), NOT Vercel.
PUBLIC_X402_INFERENCE_URL=http://localhost:4021

# x402 payment mechanism: "erc7710" = pay each inference call with a MetaMask Smart Account
# ERC-7710 delegation (the purist path; gateway must run in erc7710 mode + session key
# 7702-upgraded). "erc3009" (or unset) = the proven EIP-3009 path via the 1Shot facilitator.
PUBLIC_X402_ASSET_TRANSFER_METHOD=erc7710