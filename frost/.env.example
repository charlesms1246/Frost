# Frost desktop app — public (client-exposed) build flags. Copy to `.env`.
# Only PUBLIC_-prefixed vars are exposed to the SvelteKit/Tauri frontend.

# Cost control: when "true", the app makes NO Venice calls anywhere —
# inference falls back to OpenRouter/Groq, RPC reads/quotes use the public Base RPC
# below, and the Venice-only web_search/fetch_url tools are disabled.
# Set to "false" (or remove) to re-enable Venice for the demo.
PUBLIC_DISABLE_VENICE=true

# Public Base mainnet RPC used as the read fallback when Venice is disabled.
PUBLIC_FALLBACK_BASE_RPC_URL=https://mainnet.base.org
