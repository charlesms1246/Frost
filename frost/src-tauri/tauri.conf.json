{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "frost",
  "version": "0.1.0",
  "identifier": "app.vercel.port42",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Frost",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "center": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "/",
        "title": "Frost",
        "width": 460,
        "height": 300,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "center": true,
        "resizable": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
