{
  "name": "@frost/agent",
  "version": "0.1.0",
  "description": "Frost master-agent runtime — OpenRouter inference client + dynamic planning loop that emits validated sub-agent spawn decisions.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:live": "vitest run --config vitest.live.config.ts"
  },
  "dependencies": {
    "@1shotapi/client-sdk": "^1.1.9",
    "@frost/sdk": "file:../sdk",
    "@metamask/smart-accounts-kit": "^1.6.0",
    "@metamask/x402": "^0.2.0",
    "@x402/core": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "@x402/fetch": "^2.15.0",
    "viem": "^2.51.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
