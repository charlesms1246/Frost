# ── x402-inference gateway env ───────────────────────────────────────────────
# Copy to .env (gitignored) and fill in. See README.md for the live-settlement setup.

# Port the gateway listens on.
PORT=4021

# ── x402 payment settlement (1Shot facilitator) ──────────────────────────────
# 1Shot business credentials (same account as the executor server wallet).
ONESHOT_API_KEY=
ONESHOT_API_SECRET=

# The address that RECEIVES the per-call USDC payment (your 1Shot server wallet
# address, or any EOA you control on the target chain). x402 `payTo`.
EVM_ADDRESS=

# CAIP-2 network id for settlement. Base Sepolia = eip155:84532 (repo MVP target);
# Base mainnet = eip155:8453 (matches Venice's real x402 network).
X402_NETWORK=eip155:84532

# Price charged per /chat/completions call, as a dollar string (x402 "exact" scheme).
X402_PRICE=$0.001

# Dev/test escape hatch: when "true", the paywall is BYPASSED (no X-PAYMENT needed)
# so the endpoint can be smoke-tested and the existing agent transport can hit it
# before the client-side x402 signer lands. NEVER set true in the recorded demo.
X402_BYPASS=false

# ── upstream inference compute (proxied behind the paywall) ───────────────────
# OpenRouter is the default compute; Grok is the fallback (matches the agent runtime).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
